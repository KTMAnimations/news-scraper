# Production Environment Variables
# Copy this file to .env.production and fill in the values

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://newsuser:CHANGE_ME@postgres:5432/newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=newsdb

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== OpenSearch =====
OPENSEARCH_URL=http://opensearch:9200

# ===== Authentication =====
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== Stripe Billing =====
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ===== Frontend =====
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ===== External APIs =====
# SEC EDGAR (free, no key needed)
SEC_USER_AGENT=YourCompany contact@example.com

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# StockTwits (optional)
STOCKTWITS_ACCESS_TOKEN=

# ===== Proxy Configuration (optional) =====
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ===== Monitoring (optional) =====
SENTRY_DSN=

# ===== Backup =====
RESTIC_REPOSITORY=b2:your-bucket:news-scraper-backups
RESTIC_PASSWORD=CHANGE_ME
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# ===== Docker Registry =====
REGISTRY=ghcr.io/yourusername/news-scraper
VERSION=latest
