# Production Environment Variables
# Copy this file to .env.production and fill in the values

# ===== Environment =====
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ===== Database =====
DATABASE_URL=postgresql+asyncpg://newsuser:CHANGE_ME@postgres:5432/newsdb
DATABASE_SYNC_URL=postgresql://newsuser:CHANGE_ME@postgres:5432/newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=newsdb

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== OpenSearch =====
OPENSEARCH_URL=http://opensearch:9200

# ===== Kafka/Redpanda =====
KAFKA_BROKERS=redpanda:9092

# ===== Authentication =====
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Stripe Billing =====
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ===== Email (SMTP) =====
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=alerts@yourdomain.com
SMTP_FROM_NAME=News Scraper Alerts
SMTP_USE_TLS=true

# ===== Push Notifications (Firebase) =====
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# ===== Frontend =====
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
APP_URL=https://yourdomain.com

# ===== External APIs =====
# SEC EDGAR (free, must include valid contact email)
SEC_USER_AGENT=YourCompany contact@yourdomain.com

# Twitter/X API (optional)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Reddit (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=news-scraper:v0.1.0

# StockTwits (optional)
STOCKTWITS_ACCESS_TOKEN=

# ===== Proxy Configuration (optional) =====
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ===== Monitoring (optional) =====
SENTRY_DSN=

# ===== Backup =====
RESTIC_REPOSITORY=b2:your-bucket:news-scraper-backups
RESTIC_PASSWORD=CHANGE_ME
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# ===== Docker Registry =====
REGISTRY=ghcr.io/yourusername/news-scraper
VERSION=latest
