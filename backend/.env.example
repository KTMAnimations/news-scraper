# ==============================================================================
# Micro-Alpha News Scraper - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
# IMPORTANT: In production, use proper secrets management:
# - AWS Secrets Manager, HashiCorp Vault, or similar
# - Rotate secrets regularly (see docs/SECURITY.md)
# ==============================================================================

# ------------------------------------------------------------------------------
# Environment Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development  # development | staging | production
DEBUG=true               # Set to false in production!
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# ------------------------------------------------------------------------------
# Database Configuration
# ------------------------------------------------------------------------------
# SECURITY: Use strong passwords in production (min 16 chars, mixed case/numbers/symbols)
# Rotation: Every 180 days recommended
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/newsdb
DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/newsdb

# ------------------------------------------------------------------------------
# Redis Configuration
# ------------------------------------------------------------------------------
# Used for caching and Celery broker
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Message Queue (Kafka/Redpanda)
# ------------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092

# ------------------------------------------------------------------------------
# Search Engine
# ------------------------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200

# ------------------------------------------------------------------------------
# Authentication - CRITICAL SECURITY
# ------------------------------------------------------------------------------
# JWT_SECRET_KEY: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# SECURITY: Must be at least 32 characters. Rotate every 90 days.
# WARNING: Changing this will invalidate ALL existing sessions!
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Payment Processing (Stripe)
# ------------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
# SECURITY: Use live keys only in production. Test keys have sk_test_ prefix.
# Rotation: Annually recommended
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ------------------------------------------------------------------------------
# Data Sources - SEC EDGAR
# ------------------------------------------------------------------------------
# REQUIRED: SEC requires a valid User-Agent with contact email
# Format: "Company Name contact@company.com"
SEC_USER_AGENT=YourCompany admin@yourcompany.com

# ------------------------------------------------------------------------------
# Social Media APIs
# ------------------------------------------------------------------------------
# Twitter/X API - Get from: https://developer.twitter.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Reddit API - Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=news-scraper:v0.1.0

# StockTwits - Get from: https://stocktwits.com/developers
STOCKTWITS_ACCESS_TOKEN=

# ------------------------------------------------------------------------------
# Email Configuration (SMTP)
# ------------------------------------------------------------------------------
# Required for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=alerts@news-scraper.com
SMTP_FROM_NAME=News Scraper Alerts
SMTP_USE_TLS=true

# ------------------------------------------------------------------------------
# Push Notifications (Firebase)
# ------------------------------------------------------------------------------
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# ------------------------------------------------------------------------------
# Proxy Configuration (Optional)
# ------------------------------------------------------------------------------
# For scraping through proxies
PROXY_ENABLED=false
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ------------------------------------------------------------------------------
# Application URL
# ------------------------------------------------------------------------------
APP_URL=http://localhost:3000
