# Production Environment Configuration
# Copy this file to .env.prod and fill in the values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ===========================================
# Required Secrets (MUST BE SET)
# ===========================================

# Database credentials
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=newsdb

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-jwt-secret-key-here

# NextAuth Secret (generate with: openssl rand -hex 32)
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===========================================
# Application URLs
# ===========================================

# Public URLs (used by frontend and CORS)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_WS_URL=wss://ws.yourdomain.com
NEXTAUTH_URL=https://yourdomain.com

# ===========================================
# Docker Image Configuration
# ===========================================

# Container registry
IMAGE_REGISTRY=ghcr.io
IMAGE_REPO=ktmanimations/news-scraper
IMAGE_TAG=latest

# ===========================================
# Port Mappings (change if using reverse proxy)
# ===========================================

API_PORT=8000
WS_PORT=8001
FRONTEND_PORT=3000

# ===========================================
# Resource Configuration
# ===========================================

# Celery workers
CELERY_HIGH_CONCURRENCY=4
CELERY_HIGH_REPLICAS=2
CELERY_DEFAULT_CONCURRENCY=2
CELERY_DEFAULT_REPLICAS=1

# WebSocket workers
WS_WORKERS=2

# Redis
REDIS_MAXMEMORY=512mb

# OpenSearch
OPENSEARCH_HEAP=1g

# Redpanda
REDPANDA_SMP=2
REDPANDA_MEMORY=2G
REDPANDA_EXTERNAL_HOST=localhost

# ===========================================
# Logging
# ===========================================

LOG_LEVEL=INFO

# ===========================================
# JWT Configuration
# ===========================================

ACCESS_TOKEN_EXPIRE_MINUTES=30
